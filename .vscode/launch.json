{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Open with Edge",
      "type": "chrome",
      "request": "launch",
      "program": "C:\\Program Files (x86)\\Microsoft\\Edge\\Application\\msedge.exe",
      "runtimeArgs": [
        "--remote-debugging-port=9222"
      ],
      "url": "file://${workspaceFolder}/index.html",
      "webRoot": "${workspaceFolder}",
      "userDataDir": false
    }
  ]
}
